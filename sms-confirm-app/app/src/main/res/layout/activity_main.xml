<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تنظیمات تایید خودکار پیامک بانکی"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/textPermissionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnRequestPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="فعال‌سازی دسترسی پیامک" />

        <Button
            android:id="@+id/btnIgnoreBattery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:text="غیرفعال کردن بهینه‌سازی باتری برای این اپ" />

        <EditText
            android:id="@+id/editWebhookUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="آدرس وبهوک (مثال: https://panel.example.com/api/sms-payment/webhook)"
            android:inputType="textUri" />

        <EditText
            android:id="@+id/editDeviceId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Device ID (از پنل)"
            android:layout_marginTop="8dp"
            android:inputType="number" />

        <EditText
            android:id="@+id/editDeviceSecret"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Secret (از پنل - فقط یک‌بار نشون داده می‌شه)"
            android:layout_marginTop="8dp"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/editSenderFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="فیلتر فرستنده (پیش‌فرض: Pasargad)"
            android:layout_marginTop="8dp"
            android:inputType="text" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="ذخیره تنظیمات" />

        <Button
            android:id="@+id/btnTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="تست اتصال به سرور" />

        <TextView
            android:id="@+id/textTestResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
